# Database
POSTGRES_USER=compliance
POSTGRES_PASSWORD=compliance_dev
POSTGRES_DB=compliance_mapping
DATABASE_URL=postgresql+asyncpg://compliance:compliance_dev@localhost:5432/compliance_mapping
DATABASE_URL_SYNC=postgresql+psycopg2://compliance:compliance_dev@localhost:5432/compliance_mapping

# LLM Provider: "openai", "ollama", "watsonx", or "rule_based" (no LLM, uses heuristics)
LLM_PROVIDER=rule_based

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4

# Ollama (if LLM_PROVIDER=ollama) - for local models like Llama 2/3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# IBM watsonx.ai (if LLM_PROVIDER=watsonx)
WATSONX_API_KEY=your-ibm-api-key-here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your-project-id-here
WATSONX_MODEL=ibm/granite-3-8b-instruct

# Embedding model used for phrase similarity (sentence-transformers)
SBERT_MODEL=all-MiniLM-L6-v2
