# Copy this file to .env and fill in the values.
# The app works with no API keys (LLM_PROVIDER=rule_based uses heuristics).

# ---------------------------------------------------------------------------
# Database — matches docker-compose defaults, change if needed
# ---------------------------------------------------------------------------
POSTGRES_USER=compliance
POSTGRES_PASSWORD=compliance_dev
POSTGRES_DB=compliance_mapping

# ---------------------------------------------------------------------------
# LLM provider
# Options: bedrock | openai | watsonx | ollama | rule_based
# rule_based requires no API key and uses heuristics (less accurate)
# ---------------------------------------------------------------------------
LLM_PROVIDER=rule_based

# ---------------------------------------------------------------------------
# AWS Bedrock (if LLM_PROVIDER=bedrock)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
BEDROCK_MODEL=anthropic.claude-sonnet-4-6

# ---------------------------------------------------------------------------
# OpenAI (if LLM_PROVIDER=openai)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# ---------------------------------------------------------------------------
# IBM watsonx.ai (if LLM_PROVIDER=watsonx)
# ---------------------------------------------------------------------------
WATSONX_API_KEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_MODEL=ibm/granite-3-8b-instruct

# ---------------------------------------------------------------------------
# Ollama — local models (if LLM_PROVIDER=ollama)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# ---------------------------------------------------------------------------
# Embedding model (used for SBERT similarity — no API key needed)
# ---------------------------------------------------------------------------
SBERT_MODEL=all-MiniLM-L6-v2
